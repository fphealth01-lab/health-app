# Public site URL — used for canonical URLs, OG, sitemap, redirects
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Supabase ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Stripe ────────────────────────────────────────────────────────────────
# Test-mode keys are fine for local dev; switch to live keys only after
# Stripe verifies the business.
STRIPE_SECRET_KEY=
# Get this from `stripe listen --forward-to localhost:3000/api/stripe/webhook`.
# Reload the dev server after setting it.
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Stripe price IDs for the two paid plans (created in the Stripe dashboard).
NEXT_PUBLIC_STRIPE_PRICE_MONTHLY=
NEXT_PUBLIC_STRIPE_PRICE_YEARLY=

# ── AI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Email (Resend) ────────────────────────────────────────────────────────
RESEND_API_KEY=

# ── Admin ─────────────────────────────────────────────────────────────────
# Comma-separated emails allowed to access /admin/* (cost dashboard, etc.).
# Leave empty in production to fail closed.
ADMIN_EMAILS=
